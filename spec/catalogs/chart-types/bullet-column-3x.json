    "openxml": {
      "composition": "mixed",
      "series": [
        {
          "element": "barChart",
          "barDir": "col",
          "grouping": "stacked",
          "composition": "single"
        },
        {
          "element": "scatterChart",
          "scatterStyle": "marker",
          "composition": "single"
        }
      ],
      "notes": "Bullet columns combine threshold bands with a value marker."
